# ── MySQL (Docker Compose) ────────────────────────────────────────────────────
MYSQL_DATABASE=ai_config_wizard
MYSQL_USER=ai_config_user
MYSQL_PASSWORD=ai_config_password
MYSQL_ROOT_PASSWORD=ai_config_root_password

# ── Backend database connection ───────────────────────────────────────────────
# Used inside Docker Compose (hostname = mysql service name).
DATABASE_URL=mysql+asyncmy://ai_config_user:ai_config_password@mysql:3306/ai_config_wizard

# For local development outside Docker, replace 'mysql' with '127.0.0.1':
# DATABASE_URL=mysql+asyncmy://ai_config_user:ai_config_password@127.0.0.1:3306/ai_config_wizard

DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_NAME=ai_config_wizard
DATABASE_USER=ai_config_user
DATABASE_PASSWORD=ai_config_password

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave blank for localhost-only).
ALLOWED_ORIGINS=

# ── Config source (Phase 1: always json) ─────────────────────────────────────
CONFIG_SOURCE=json

# ── Auth ─────────────────────────────────────────────────────────────────────
# Set to 'true' to enable header-based authentication.
AUTH_ENABLED=false

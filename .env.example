# ============================================================
# AI Accelerator - Environment Variable Reference
# Copy this file to .env and fill in production values.
# Never commit a .env file containing real secrets.
# ============================================================

# MySQL (Docker Compose)
MYSQL_DATABASE=ai_config_wizard
MYSQL_USER=ai_config_user
MYSQL_PASSWORD=CHANGE_ME
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT

# Database Connection
DATABASE_URL=mysql+asyncmy://ai_config_user:CHANGE_ME@mysql:3306/ai_config_wizard
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_NAME=ai_config_wizard
DATABASE_USER=ai_config_user
DATABASE_PASSWORD=CHANGE_ME

# Database SSL (required for Azure Database for MySQL)
# Download CA cert: https://dl.cacerts.digicert.com/DigiCertGlobalRootCA.crt.pem
DB_SSL_CA=/etc/ssl/certs/DigiCertGlobalRootCA.crt.pem
# Options: DISABLED | REQUIRED | VERIFY_CA | VERIFY_IDENTITY
DB_SSL_MODE=VERIFY_CA

# Database Connection Pool
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800

# Authentication - MUST be true in production
# Auth is enforced via reverse-proxy headers (X-Auth-User / X-Auth-Roles)
AUTH_ENABLED=true

# CORS - comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend-domain.azurecontainerapps.io

# Frontend API URL (Vite build-time variable)
VITE_API_BASE_URL=https://your-backend-domain.azurecontainerapps.io

# Config source
CONFIG_SOURCE=database

# Logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Server port
PORT=8000

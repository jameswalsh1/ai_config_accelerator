{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "test: backend (pytest)",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/bin/python -m pytest tests/ -q",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "test: frontend (vitest)",
      "type": "shell",
      "command": "npm run test -- --run",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "test: all (parallel)",
      "dependsOn": [
        "test: backend (pytest)",
        "test: frontend (vitest)"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}

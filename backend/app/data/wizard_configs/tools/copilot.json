{
  "tool_id": "copilot",
  "tool_metadata": {
    "title": "GitHub Copilot Configuration",
    "description": "Generate repository-wide custom instructions, path-specific custom instructions, agent skills, prompt files, custom agents, and repository settings for GitHub Copilot.",
    "target": "copilot",
    "schema_version": "1.0",
    "target_version_constraints": {
      "copilot": "enterprise-cloud-latest"
    },
    "output_preview_targets": [
      {
        "target": "repo_instructions",
        "label": ".github/copilot-instructions.md"
      },
      {
        "target": "path_instructions",
        "label": ".github/instructions/*.instructions.md"
      },
      {
        "target": "agent_skills",
        "label": ".github/skills/*"
      },
      {
        "target": "prompt_files",
        "label": ".github/prompts/*"
      },
      {
        "target": "agent_instruction_files",
        "label": "AGENTS.md (root or nested)"
      },
      {
        "target": "custom_agents",
        "label": ".github/agents/*"
      },
      {
        "target": "repo_settings",
        "label": ".github/copilot/settings.json"
      }
    ]
  },
  "version": "1.0",
  "applies_to": {
    "tools": [
      "copilot"
    ]
  },

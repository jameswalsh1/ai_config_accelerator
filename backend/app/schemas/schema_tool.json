{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tool Override Schema",
  "description": "JSON Schema for tool/*.json override files - defines tool-specific controls and visibility",
  "type": "object",
  "required": ["tool_id"],
  "properties": {
    "tool_id": {
      "type": "string",
      "description": "Tool identifier",
      "pattern": "^[a-z0-9_]+$"
    },
    "tool_metadata": {
      "type": "object",
      "description": "Tool metadata and configuration",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "target": { "type": "string" },
        "schema_version": { "type": "string" },
        "target_version_constraints": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "output_preview_targets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "target": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        }
      }
    },
    "metadata_overrides": {
      "type": "array",
      "description": "Overrides for field metadata",
      "items": {
        "type": "object",
        "required": ["field_id"],
        "properties": {
          "field_id": {
            "type": "string",
            "description": "Target field ID (dot notation: step.field)",
            "pattern": "^[a-z0-9_.]+$"
          },
          "default": { "description": "New default value" },
          "editability": {
            "type": "string",
            "enum": ["free", "locked", "suggested", "defaulted"]
          },
          "required": { "type": "boolean" },
          "hidden": { "type": "boolean" }
        }
      }
    },
    "field_overrides": {
      "type": "array",
      "description": "Overrides for field structure",
      "items": {
        "type": "object",
        "required": ["field_id"],
        "properties": {
          "field_id": {
            "type": "string",
            "pattern": "^[a-z0-9_.]+$"
          },
          "options": { "type": "array" },
          "presets": { "type": "array" },
          "merge_presets": { "type": "array" },
          "validation": { "type": "object" }
        }
      }
    },
    "step_overrides": {
      "type": "array",
      "description": "Overrides for step visibility and metadata",
      "items": {
        "type": "object",
        "required": ["step_id"],
        "properties": {
          "step_id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "hidden": { "type": "boolean" },
          "title": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": true
}
